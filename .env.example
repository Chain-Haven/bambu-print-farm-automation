# Antigravity Environment Configuration
# Copy this to .env and fill in values

# Server
PORT=3000
HOST=0.0.0.0

# Auth
JWT_SECRET=change-me-to-a-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=antigravity

# Database
DB_PATH=./data/antigravity.db

# Encryption key for printer auth credentials (32 hex chars = 16 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Logging
LOG_LEVEL=info

# Cloud control plane (Vercel server-side only)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=server-side-only
NODE_TOKEN_PEPPER=change-me
CLOUD_ADMIN_TOKEN=change-me
# Pepper story: every pkx_* credential is stored as sha256("pepper:token").
#  - NODE_TOKEN_PEPPER      -> farm node tokens (pkx_node_*). Agent routes use
#                              ONLY this pepper (no fallback) and it is the
#                              fallback for all the peppers below.
#  - MERCHANT_API_KEY_PEPPER-> merchant live keys (pkx_live_*), setup tokens
#                              (pkx_setup_*), and portal sessions
#                              (pkx_muser_session_*).
#  - ADMIN_SESSION_PEPPER   -> admin sessions/resets (pkx_admin_*).
#  - MERCHANT_REALTIME_TOKEN_PEPPER -> realtime channel tokens.
# Set them explicitly to rotate each credential family independently.
MERCHANT_API_KEY_PEPPER=change-me
ADMIN_SESSION_PEPPER=change-me
# MERCHANT_REALTIME_TOKEN_PEPPER=change-me
# Required (fails closed, no fallback): AES key used to encrypt merchant webhook
# signing secrets. POST /api/public/webhooks returns HTTP 500 until this is set.
MERCHANT_WEBHOOK_SIGNING_SECRET_KEY=change-me-to-a-long-random-secret

# Password reset emails (admin + merchant sign-in). Optional: without these the
# forgot-password endpoints still respond generically, and reset links are only
# written to the server log / issued by super admins from the console.
# RESEND_API_KEY=re_your_resend_api_key
# EMAIL_FROM=PrintKinetix <no-reply@yourdomain.com>
# APP_BASE_URL=https://your-vercel-deployment.vercel.app
# Login/reset throttles (per email, requests per minute; <=0 disables)
# ADMIN_LOGIN_RATE_LIMIT_RPM=10
# MERCHANT_LOGIN_RATE_LIMIT_RPM=10

# Admin migration runner direct Postgres connection (Vercel production only)
# Preferred: use a non-pooling URL for DDL migrations.
POSTGRES_URL_NON_POOLING=postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Accepted fallbacks: POSTGRES_URL or POSTGRES_PRISMA_URL.
# If URL vars are unavailable, set all split vars below instead.
# POSTGRES_HOST=HOST
# POSTGRES_PORT=5432
# POSTGRES_USER=USER
# POSTGRES_PASSWORD=PASSWORD
# POSTGRES_DATABASE=postgres

# Local Windows/NUC node (agent-side only)
CLOUD_API_URL=https://your-vercel-deployment.vercel.app
LOCAL_NODE_TOKEN=pkx_node_change_me
CLOUD_COMMAND_POLL_INTERVAL_MS=2000
CLOUD_HEARTBEAT_INTERVAL_MS=30000

# Device Runtime
MQTT_RECONNECT_INTERVAL_MS=5000
HEALTH_CHECK_INTERVAL_MS=30000
COMMAND_POLL_INTERVAL_MS=1000

# Mock mode (uses simulators instead of real hardware)
MOCK_MODE=true

# --- AI-agent MCP server + USDC payments (cloud/Vercel side) ---
# Agents connect to POST /api/mcp and pay per gram of filament in USDC,
# straight to YOUR wallet. Set the wallet address to enable the flow.
# USDC_WALLET_ADDRESS=0xYourSelfHostedWalletAddress
# USDC_CHAIN=base                # base | ethereum | polygon | arbitrum
# USDC_PRICE_PER_GRAM=0.05       # USDC charged per gram of filament
# USDC_SHIPPING_FLAT=8           # USDC per order for tracked shipping
# USDC_MIN_CONFIRMATIONS=2
# EVM_RPC_URL=                   # optional: your own RPC endpoint
# USDC_TOKEN_ADDRESS=            # optional: override the chain's USDC contract
# Tiered agent pricing (optional): per-material overrides + one volume break.
# USDC_PRICE_PER_GRAM_PETG=0.07
# USDC_VOLUME_BREAK_GRAMS=500
# USDC_VOLUME_DISCOUNT_PCT=10
# x402 agent payments (optional): facilitator that verifies + broadcasts
# signed transfers (funds still land in USDC_WALLET_ADDRESS).
# X402_FACILITATOR_URL=https://x402.org/facilitator
