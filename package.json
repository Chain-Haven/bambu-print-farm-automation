{
  "name": "antigravity",
  "version": "1.0.0",
  "description": "Multi-Printer Orchestrator for Bambu 3D Printers",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "local-node": "node src/cloud/runLocalNode.js",
    "build:node": "node scripts/build-windows-node.mjs",
    "build:node:exe": "node scripts/build-windows-node.mjs --exe",
    "test": "vitest run",
    "test:cloud": "vitest run tests/cloud",
    "e2e:live": "npx --yes --package=playwright node scripts/live-e2e-test.mjs",
    "e2e:local": "node scripts/local-e2e-test.mjs",
    "test:watch": "vitest",
    "cloud:smoke": "node scripts/cloud-smoke-test.js",
    "cli": "node src/gcode/cli.js"
  },
  "bin": {
    "ag-gcode-transform": "./src/gcode/cli.js"
  },
  "keywords": [
    "3d-printing",
    "bambu",
    "print-farm",
    "automation"
  ],
  "license": "MIT",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "adm-zip": "^0.5.16",
    "basic-ftp": "^5.2.0",
    "bcryptjs": "^2.4.3",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.10.4",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "sql.js": "^1.12.0",
    "unzipper": "^0.12.3",
    "uuid": "^11.0.5",
    "ws": "^8.18.1",
    "yauzl": "^3.2.0"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6",
    "vitest": "^3.0.5"
  }
}
