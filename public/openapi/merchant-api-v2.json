      "InvoiceId": { "name": "invoice_id", "in": "path", "required": true, "schema": { "type": "string" } },
      "WebhookId": { "name": "webhook_id", "in": "path", "required": true, "schema": { "type": "string" } }
    },
    "requestBodies": {
      "JsonObject": { "required": false, "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } } },
      "FileCreate": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateFileRequest" } } } },
      "OrderCreate": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateOrderRequest" } } } },
      "WebhookCreate": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateWebhookRequest" } } } }
    },
    "responses": {
