          "metadata": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      },
      "WebhookDelivery": {
        "type": "object",
        "properties": {
          "delivery_id": { "type": "string" },
          "webhook_id": { "type": "string" },
          "event_type": { "type": "string" },
          "status": { "type": "string" },
          "response_status": { "type": "integer" },
