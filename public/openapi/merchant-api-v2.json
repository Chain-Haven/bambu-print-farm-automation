      "File": { "description": "File response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "file": { "$ref": "#/components/schemas/File" } } }] } } } },
      "Slice": { "description": "Slice response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "slice": { "$ref": "#/components/schemas/Slice" } } }] } } } },
      "Order": { "description": "Order response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "order": { "$ref": "#/components/schemas/Order" } } }] } } } },
      "RoutingEstimate": { "description": "Routing estimate response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "estimate": { "$ref": "#/components/schemas/RoutingEstimate" } } }] } } } },
      "JobEvents": { "description": "Job events response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "events": { "type": "array", "items": { "$ref": "#/components/schemas/PrintJobEvent" } } } }] } } } },
      "JobArtifacts": { "description": "Job artifacts response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "artifacts": { "type": "array", "items": { "$ref": "#/components/schemas/JobArtifact" } } } }] } } } },
      "Inspection": { "description": "Inspection response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "inspection": { "$ref": "#/components/schemas/Inspection" } } }] } } } },
      "PostProcessingTask": { "description": "Post-processing task response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "task": { "$ref": "#/components/schemas/PostProcessingTask" } } }] } } } },
      "PostProcessingTasks": { "description": "Post-processing tasks response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "tasks": { "type": "array", "items": { "$ref": "#/components/schemas/PostProcessingTask" } } } }] } } } },
      "MaterialReservation": { "description": "Material reservation response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "reservation": { "$ref": "#/components/schemas/MaterialReservation" } } }] } } } },
      "Batch": { "description": "Batch response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "batch": { "$ref": "#/components/schemas/Batch" } } }] } } } },
      "Shipment": { "description": "Shipment response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "shipment": { "$ref": "#/components/schemas/Shipment" } } }] } } } },
      "Shipments": { "description": "Shipments response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "shipments": { "type": "array", "items": { "$ref": "#/components/schemas/Shipment" } } } }] } } } },
      "ShippingLabel": { "description": "Shipping label response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "label": { "$ref": "#/components/schemas/ShippingLabel" } } }] } } } },
      "RateCard": { "description": "Rate card response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "rate_card": { "$ref": "#/components/schemas/RateCard" } } }] } } } },
      "UsageLines": { "description": "Usage lines response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "usage": { "type": "array", "items": { "$ref": "#/components/schemas/UsageLine" } } } }] } } } },
      "Invoice": { "description": "Invoice response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "invoice": { "$ref": "#/components/schemas/Invoice" } } }] } } } },
      "Invoices": { "description": "Invoices response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "invoices": { "type": "array", "items": { "$ref": "#/components/schemas/Invoice" } } } }] } } } },
      "InvoicePreview": { "description": "Invoice preview response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "preview": { "$ref": "#/components/schemas/InvoicePreview" } } }] } } } },
      "RealtimeToken": { "description": "Realtime token response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "token": { "$ref": "#/components/schemas/RealtimeToken" } } }] } } } },
      "RealtimeTokens": { "description": "Realtime tokens response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "tokens": { "type": "array", "items": { "$ref": "#/components/schemas/RealtimeToken" } } } }] } } } },
      "WebhookEndpoint": { "description": "Webhook endpoint response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "webhook": { "$ref": "#/components/schemas/WebhookEndpoint" }, "signing_secret": { "type": "string", "description": "Returned only once on create." } } }] } } } },
      "WebhookEndpoints": { "description": "Webhook endpoints response", "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/ApiResponse" }, { "type": "object", "properties": { "webhooks": { "type": "array", "items": { "$ref": "#/components/schemas/WebhookEndpoint" } } } }] } } } }
