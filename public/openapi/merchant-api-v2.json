      "SliceId": { "name": "slice_id", "in": "path", "required": true, "schema": { "type": "string" } },
      "OrderId": { "name": "order_id", "in": "path", "required": true, "schema": { "type": "string" } },
      "JobId": { "name": "job_id", "in": "path", "required": true, "schema": { "type": "string" } },
      "JobIdQuery": { "name": "job_id", "in": "query", "required": true, "schema": { "type": "string" } },
      "InspectionId": { "name": "inspection_id", "in": "path", "required": true, "schema": { "type": "string" } },
