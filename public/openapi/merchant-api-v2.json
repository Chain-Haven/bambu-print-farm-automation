    "schemas": {
      "ApiResponse": {
        "type": "object",
        "required": ["ok", "request_id"],
        "properties": {
          "ok": { "type": "boolean" },
          "request_id": { "type": "string" }
        },
        "additionalProperties": true
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["ok", "error", "message", "request_id"],
        "properties": {
          "ok": { "const": false },
          "error": { "type": "string" },
          "message": { "type": "string" },
          "request_id": { "type": "string" }
        }
      },
      "CreateFileRequest": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "content_type": { "type": "string" },
              "size_bytes": { "type": "integer" },
              "checksum_sha256": { "type": "string" }
            },
            "additionalProperties": true
          },
          "metadata": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      },
      "File": {
        "type": "object",
        "required": ["file_id", "status", "file_mode"],
