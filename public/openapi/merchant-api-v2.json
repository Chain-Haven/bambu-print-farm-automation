          "status": { "type": "string" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/OrderItem" } },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "metadata": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "item_id": { "type": "string" },
          "file_id": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 },
          "requirements": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      },
      "RoutingEstimate": {
        "type": "object",
        "properties": {
          "strategy": { "type": "string" },
          "estimated_print_minutes": { "type": "number" },
          "estimated_queue_minutes": { "type": "number" },
          "estimated_cost": { "type": "number" },
          "currency": { "type": "string" },
          "options": { "type": "array", "items": { "$ref": "#/components/schemas/RoutingOption" } }
        },
        "additionalProperties": true
      },
      "RoutingOption": {
        "type": "object",
        "properties": {
          "routing_strategy": { "type": "string" },
          "lead_time_minutes": { "type": "number" },
          "available": { "type": "boolean" }
        },
        "additionalProperties": true
      },
      "PrintJobEvent": {
        "type": "object",
        "properties": {
          "event_id": { "type": "string" },
          "job_id": { "type": "string" },
