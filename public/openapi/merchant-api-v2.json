          "created_at": { "type": "string", "format": "date-time" },
          "metadata": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      },
      "Shipment": {
        "type": "object",
        "properties": {
          "shipment_id": { "type": "string" },
          "status": { "type": "string" },
