{
  "openapi": "3.1.0",
  "info": {
    "title": "PrintKinetix Merchant API",
    "version": "1.0.0",
    "summary": "Merchant signup, API keys, print job ingestion, routing, and usage tracking."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "security": [
    {
      "MerchantApiKey": []
    }
  ],
  "paths": {
    "/api/public/merchants/signup": {
      "post": {
        "summary": "Create a merchant signup request",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MerchantSignupRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Merchant created"
          },
          "409": {
            "description": "Merchant email already exists"
          }
        }
      }
    },
    "/api/public/farm/filaments": {
      "get": {
        "summary": "Read public aggregate farm filament availability",
        "description": "Unauthenticated aggregate material and color availability. Internal spool IDs, printer IDs, locations, lot codes, and reserved jobs are not exposed.",
        "security": [],
        "responses": {
          "200": {
            "description": "Public filament availability",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicFilamentAvailabilityResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/merchant/me": {
      "get": {
        "summary": "Read authenticated merchant account",
        "responses": {
          "200": {
            "description": "Authenticated merchant"
          }
        }
      }
    },
    "/api/public/api-keys": {
      "get": {
        "summary": "List merchant API keys",
        "responses": {
          "200": {
            "description": "API key list without raw secrets or hashes"
          }
        }
      },
      "post": {
        "summary": "Create a live merchant API key",
        "description": "Use MerchantApiKey to create an additional key, or MerchantSetupToken to exchange a one-time setup token.",
        "security": [
          {
            "MerchantApiKey": []
          },
          {
            "MerchantSetupToken": []
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateApiKeyRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created live key. The raw key is returned once as api_key_secret."
          }
        }
      }
    },
    "/api/public/api-keys/revoke": {
      "post": {
        "summary": "Revoke a merchant API key",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RevokeApiKeyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Key revoked"
          }
        }
      }
    },
    "/api/public/print-jobs": {
      "get": {
        "summary": "List merchant print jobs",
        "parameters": [
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Merchant jobs"
          }
        }
      },
      "post": {
        "summary": "Submit a print file",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePrintJobRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Print job accepted"
          }
        }
      }
    },
    "/api/public/print-jobs/status": {
      "get": {
        "summary": "Read one print job by id",
        "parameters": [
          {
            "name": "job_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Print job status"
          },
          "404": {
            "description": "Print job not found"
          }
        }
      }
    },
    "/api/cloud/merchants": {
      "get": {
        "summary": "Admin list merchants",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Merchant list"
          }
        }
      },
      "post": {
        "summary": "Admin approve, activate, reject, or suspend merchant",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminMerchantActionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Merchant status updated"
          }
        }
      }
    },
    "/api/cloud/farm-automation": {
      "get": {
        "summary": "Admin read farm automation policy, filament inventory, integrations, and planner output",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "parameters": [
          {
            "name": "org_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Farm automation settings and current operations plan"
          }
        }
      },
      "patch": {
        "summary": "Admin update farm automation policy, filament inventory, or integrations",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FarmAutomationUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Farm automation settings updated"
          }
        }
      }
    },
    "/api/cloud/merchant-settings": {
      "get": {
        "summary": "Admin read merchant settings",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Merchant settings"
          }
        }
      },
      "patch": {
        "summary": "Admin update full-auto merchant mode",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "full_auto_merchant_mode"
                ],
                "properties": {
                  "full_auto_merchant_mode": {
                    "type": "boolean",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings updated"
          }
        }
      }
    },
    "/api/cloud/merchant-setup-token": {
      "post": {
        "summary": "Admin issue one-time setup token for an active merchant",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "merchant_id"
                ],
                "properties": {
                  "merchant_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Setup token returned once"
          }
        }
      }
    },
    "/api/cloud/merchant-api-keys": {
      "get": {
        "summary": "Admin list live API keys for a merchant",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "parameters": [
          {
            "name": "merchant_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Merchant API key list without raw secrets or hashes"
          }
        }
      },
      "post": {
        "summary": "Admin issue a live API key for an active merchant",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminMerchantApiKeyRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created live key. The raw key is returned once as api_key_secret."
          }
        }
      },
      "delete": {
        "summary": "Admin revoke a merchant API key",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminMerchantApiKeyRevokeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API key revoked"
          },
          "404": {
            "description": "API key not found"
          }
        }
      }
    },
    "/api/cloud/merchant-jobs": {
      "get": {
        "summary": "Admin list jobs for a merchant",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "parameters": [
          {
            "name": "merchant_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Merchant print jobs"
          }
        }
      }
    },
    "/api/cloud/merchant-usage": {
      "get": {
        "summary": "Admin list tracked usage for a merchant",
        "security": [
          {
            "CloudAdminToken": []
          }
        ],
        "parameters": [
          {
            "name": "merchant_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Merchant usage events"
          }
        }
      }
    },
    "/api/public/farm/capabilities": {
      "get": {
        "summary": "Read public aggregate farm capabilities",
        "description": "Unauthenticated public capabilities: accepted file types, routing strategies, max build volume, feature readiness, and safe filament availability.",
        "security": [],
        "responses": {
          "200": {
            "description": "Public farm capabilities"
          }
        }
      }
    },
    "/api/public/quotes": {
      "post": {
        "summary": "Estimate print cost and lead time",
        "description": "Merchant-authenticated quote endpoint. Does not create a print job.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QuoteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quote and route estimate"
          }
        }
      }
    },
    "/api/public/print-jobs/preflight": {
      "post": {
        "summary": "Preflight a print request before creating a job",
        "description": "Validates file type, dimensions, routing capacity, review flags, and estimated quote.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PreflightRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Preflight result"
          }
        }
      }
    },
    "/api/public/print-jobs/approve": {
      "post": {
        "summary": "Approve a print job",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PrintJobLifecycleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "approve result"
          }
        }
      }
    },
    "/api/public/print-jobs/cancel": {
      "post": {
        "summary": "Cancel a print job",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PrintJobLifecycleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "cancel result"
          }
        }
      }
    },
    "/api/public/print-jobs/reprint": {
      "post": {
        "summary": "Reprint a print job",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PrintJobLifecycleRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "reprint result"
          }
        }
      }
    },
    "/api/public/webhooks": {
      "get": {
        "summary": "Read merchant webhook configuration",
        "responses": {
          "200": {
            "description": "Webhook configuration with secret redacted"
          }
        }
      },
      "post": {
        "summary": "Create or update merchant webhook configuration",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookConfigRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook configuration saved"
          }
        }
      }
    },
    "/api/public/integrations": {
      "get": {
        "summary": "List supported merchant integrations",
        "security": [],
        "responses": {
          "200": {
            "description": "Integration catalog"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "MerchantApiKey": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "pkx_live"
      },
      "MerchantSetupToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Merchant-Setup-Token"
      },
      "CloudAdminToken": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "parameters": {
      "Limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 50
        }
      }
    },
    "schemas": {
      "MerchantSignupRequest": {
        "type": "object",
        "required": [
          "company_name",
          "contact_email"
        ],
        "properties": {
          "company_name": {
            "type": "string"
          },
          "contact_email": {
            "type": "string",
            "format": "email"
          },
          "contact_name": {
            "type": "string"
          },
          "website": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "CreateApiKeyRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "default": "Production"
          }
        }
      },
      "RevokeApiKeyRequest": {
        "type": "object",
        "required": [
          "key_id"
        ],
        "properties": {
          "key_id": {
            "type": "string"
          }
        }
      },
      "CreatePrintJobRequest": {
        "type": "object",
        "required": [
          "file"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "file": {
            "type": "object",
            "required": [
              "name",
              "base64"
            ],
            "properties": {
              "name": {
                "type": "string",
                "examples": [
                  "part.gcode.3mf"
                ]
              },
              "content_type": {
                "type": "string",
                "default": "application/octet-stream"
              },
              "base64": {
                "type": "string",
                "contentEncoding": "base64"
              }
            }
          },
          "requirements": {
            "type": "object",
            "properties": {
              "dimensions_mm": {
                "type": "object",
                "properties": {
                  "x": {
                    "type": "number"
                  },
                  "y": {
                    "type": "number"
                  },
                  "z": {
                    "type": "number"
                  }
                }
              },
              "materials": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "colors": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          },
          "options": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "AdminMerchantActionRequest": {
        "type": "object",
        "required": [
          "merchant_id",
          "action"
        ],
        "properties": {
          "merchant_id": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "approve",
              "activate",
              "reject",
              "suspend"
            ]
          },
          "issue_setup_token": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "AdminMerchantApiKeyRequest": {
        "type": "object",
        "required": [
          "merchant_id"
        ],
        "properties": {
          "merchant_id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "default": "Production"
          }
        }
      },
      "AdminMerchantApiKeyRevokeRequest": {
        "type": "object",
        "required": [
          "merchant_id",
          "key_id"
        ],
        "properties": {
          "merchant_id": {
            "type": "string"
          },
          "key_id": {
            "type": "string"
          }
        }
      },
      "FarmAutomationUpdateRequest": {
        "type": "object",
        "properties": {
          "policy": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "smart_queue_enabled": {
                "type": "boolean"
              },
              "auto_eject_enabled": {
                "type": "boolean"
              },
              "failure_detection_enabled": {
                "type": "boolean"
              },
              "release_temperature_c": {
                "type": "number"
              },
              "max_eject_attempts": {
                "type": "integer"
              },
              "bed_clear_verification": {
                "type": "string"
              }
            }
          },
          "inventory": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "spools": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "integrations": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "PublicFilamentAvailabilityResponse": {
        "type": "object",
        "required": [
          "ok",
          "filaments"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "filaments": {
            "type": "object",
            "required": [
              "materials",
              "colors",
              "updated_at"
            ],
            "properties": {
              "materials": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PublicFilamentMaterial"
                }
              },
              "colors": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PublicFilamentColor"
                }
              },
              "updated_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              }
            }
          }
        }
      },
      "PublicFilamentMaterial": {
        "type": "object",
        "required": [
          "material",
          "spool_count",
          "available_spool_count",
          "total_grams_remaining",
          "available_grams_remaining",
          "colors"
        ],
        "properties": {
          "material": {
            "type": "string",
            "examples": [
              "PLA"
            ]
          },
          "spool_count": {
            "type": "integer"
          },
          "available_spool_count": {
            "type": "integer"
          },
          "total_grams_remaining": {
            "type": "number"
          },
          "available_grams_remaining": {
            "type": "number"
          },
          "colors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PublicFilamentColor"
            }
          }
        }
      },
      "PublicFilamentColor": {
        "type": "object",
        "required": [
          "color_hex",
          "color_name",
          "spool_count",
          "available_spool_count",
          "total_grams_remaining",
          "available_grams_remaining"
        ],
        "properties": {
          "color_hex": {
            "type": "string",
            "examples": [
              "#FFFFFF"
            ]
          },
          "color_name": {
            "type": [
              "string",
              "null"
            ],
            "examples": [
              "White"
            ]
          },
          "materials": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "spool_count": {
            "type": "integer"
          },
          "available_spool_count": {
            "type": "integer"
          },
          "total_grams_remaining": {
            "type": "number"
          },
          "available_grams_remaining": {
            "type": "number"
          }
        }
      },
      "QuoteRequest": {
        "type": "object",
        "properties": {
          "requirements": {
            "$ref": "#/components/schemas/PrintRequirements"
          },
          "options": {
            "type": "object",
            "properties": {
              "routing_strategy": {
                "type": "string",
                "enum": [
                  "fastest_fulfillment",
                  "batch_by_material",
                  "least_printer_wear",
                  "ship_cutoff"
                ]
              }
            }
          }
        }
      },
      "PreflightRequest": {
        "type": "object",
        "properties": {
          "file": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "byte_size": {
                "type": "number"
              }
            }
          },
          "requirements": {
            "$ref": "#/components/schemas/PrintRequirements"
          },
          "options": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "PrintRequirements": {
        "type": "object",
        "properties": {
          "dimensions_mm": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              },
              "z": {
                "type": "number"
              }
            }
          },
          "materials": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "colors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "estimated_grams": {
            "type": "number"
          }
        }
      },
      "PrintJobLifecycleRequest": {
        "type": "object",
        "required": [
          "job_id"
        ],
        "properties": {
          "job_id": {
            "type": "string"
